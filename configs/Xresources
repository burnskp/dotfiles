Xft.dpi:    120
Xft.antialias:  1
Xft.autohint:   0
Xft.hinting:    1
Xft.hintstyle:  hintfull
Xft.lcdfilter:  lcddefault
Xft.rgba:       rgb

! urxvt
URxvt*buffered: true
URxvt*cursorBlink: true
URxvt*underlineColor: yellow
URxvt*font:  xft:DejaVu Sans Mono:style=Book:size=20:antialias=true
URxvt*depth: 32
URxvt*borderless: 1
URxvt*scrollBar: false
URxvt*scrollTtyOutput: false
URxvt*scrollWithBuffer: true
URxvt*scrollTtyKeypress: true
URxvt*loginShell: true
Urxvt*secondaryScroll: true
URxvt*saveLines: 5000
URxvt*termName: rxvt-unicode
URxvt.fading: false
URxvt*urgentOnBell: true

! st
st*font: DejaVuSansM Nerd Font Mono:pixelsize=32:antialias=true:autohint=true
st*termName: st
st*blinktimeout: 800
st*bellvolume: 0
st*curorshape: 2
st*borderpx: 10
st*cwscale: 1.0
st*chscale: 1.0

